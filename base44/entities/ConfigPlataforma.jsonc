{
  "name": "ConfigPlataforma",
  "type": "object",
  "properties": {
    "clave": {
      "type": "string",
      "default": "plataforma",
      "description": "Clave \u00fanica singleton"
    },
    "ycloud_api_key": {
      "type": "string",
      "description": "API key maestra YCloud Tech Partner"
    },
    "ycloud_webhook_url_base44": {
      "type": "string",
      "default": "https://69f2d5cf8bf1f0b0a3b84645.base44.app/api/functions/ycloudWebhook",
      "description": "URL p\u00fablica del webhook de Base44"
    },
    "ycloud_webhook_id": {
      "type": "string",
      "description": "ID del webhook registrado en YCloud"
    },
    "ycloud_modo": {
      "type": "string",
      "enum": [
        "manual",
        "automatico"
      ],
      "default": "manual",
      "description": "Modo de alta: manual o autom\u00e1tico (Tech Partner)"
    },
    "meta_app_id": {
      "type": "string",
      "description": "Facebook App ID"
    },
    "meta_config_id": {
      "type": "string",
      "description": "Facebook Login for Business Configuration ID"
    },
    "meta_solution_id": {
      "type": "string",
      "description": "Solution ID de YCloud"
    },
    "meta_modo": {
      "type": "string",
      "enum": [
        "pendiente",
        "activo"
      ],
      "default": "pendiente",
      "description": "Estado del Embedded Signup"
    },
    "openai_api_key": {
      "type": "string",
      "description": "API key de OpenAI"
    },
    "openai_modelo": {
      "type": "string",
      "enum": [
        "gpt-4o-mini",
        "gpt-4o",
        "gpt-3.5-turbo"
      ],
      "default": "gpt-4o-mini",
      "description": "Modelo de OpenAI por defecto"
    },
    "stripe_secret_key": {
      "type": "string"
    },
    "stripe_webhook_secret": {
      "type": "string"
    },
    "stripe_price_id_pro": {
      "type": "string",
      "description": "Price ID del plan Pro 49\u20ac/mes"
    },
    "stripe_price_id_instalacion": {
      "type": "string",
      "description": "Price ID del pago \u00fanico 69\u20ac"
    },
    "limite_mensajes_global": {
      "type": "number",
      "default": 200,
      "description": "L\u00edmite mensual de mensajes por proyecto"
    },
    "notas_admin": {
      "type": "string",
      "description": "Notas internas del administrador"
    }
  },
  "required": [
    "clave"
  ]
}